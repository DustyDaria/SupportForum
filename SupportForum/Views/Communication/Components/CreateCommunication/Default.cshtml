@model SupportForum.Models.ViewModels.CommunicationViewModel

<div class="row">
    <div class="col-md-4">
        <form asp-controller="Communication" asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Communication.TextMsg" class="control-label"></label>
                <input asp-for="Communication.TextMsg" class="form-control" />
                <span asp-validation-for="Communication.TextMsg" class="text-danger"></span>
            </div>

            @Html.HiddenFor(model => model.Communication.IdParent)
            @Html.HiddenFor(model => model.Communication.IdTopic)
            @Html.Hidden("Communication.TimeCreate", DateTime.Now)

            @Html.HiddenFor(model => model.IdTopic)
            @Html.HiddenFor(model => model.Communication.IdInitiator)
            @Html.HiddenFor(model => model.Communication.IdInitiatorNavigation.FullName)
            @Html.HiddenFor(model => model.Communication.IdInitiatorNavigation.Domen)
            @Html.HiddenFor(model => model.Communication.IdInitiatorNavigation.UserLogin)

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>



