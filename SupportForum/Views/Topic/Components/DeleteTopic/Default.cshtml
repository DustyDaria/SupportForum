@model SupportForum.Models.ViewModels.TopicViewModel

<div>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Topic.IdForum)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Topic.IdForumNavigation.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Topic.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Topic.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Topic.Descriptions)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Topic.Descriptions)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Topic.IsAnonymous)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Topic.IsAnonymous)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Topic.IdInitiator)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Topic.IdInitiatorNavigation.FullName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Topic.TimeCreate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Topic.TimeCreate)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Topic.Id" />
        <input type="hidden" asp-for="IdForumCategory" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
    </form>
