@model SupportForum.Models.TblUser

@{
    ViewData["Title"] = "Edit";
    Layout = "_User.cshtml";
}

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="UserLogin" class="control-label"></label>
                <input asp-for="UserLogin" class="form-control" />
                <span asp-validation-for="UserLogin" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CurrRole" class="control-label"></label>
                <input asp-for="CurrRole" class="form-control" />
                <span asp-validation-for="CurrRole" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DateLastActivity" class="control-label"></label>
                <input asp-for="DateLastActivity" class="form-control" />
                <span asp-validation-for="DateLastActivity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

