@addTagHelper *, ViewComponentSample
@using Microsoft.AspNetCore.Components;
@addTagHelper *, RazorPages

@model SupportForum.Models.ViewModels.ForumViewModel

@{
    Layout = "_Forum.cshtml";
}

<h1>
    @if(Model.Category.IsModeration == true)
    {
        <a title="Создать форум" class="btn rounded-circle lh-1" data-bs-toggle="offcanvas" data-bs-target="#offcanvasActionForum" 
            aria-controls="offcanvasActionForum" onclick="GetCreateForumVC(1,@Model.Category.Id );" >
            <img src="/src/person-plus.svg" width="24" height="24" />
        </a>
    }
    @Model.Category.Title
</h1>

<div class="offcanvas offcanvas-end text-bg-dark" tabindex="-1" id="offcanvasActionForum" aria-labelledby="offcanvasActionForumLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="offcanvasActionForumLabel"></h5>
        <button type="button" class="btn-close btn-close btn-close-black" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body" id="pnlOffcanvasBody">
    </div>
</div>

@using (Html.BeginForm())
{
    <div class="treeview" id="forumTreeView">
        @{
            ShowTreeData(Model.Forums.Where(w => w.IdParent == null && w.IdCategory != null));
        }
    </div>
}

@functions {
    
    public void ShowTreeData(IEnumerable<SupportForum.Models.TblForum> model)
    {
        <ul class="list-group">
            @foreach (var item in model)
            {
                <li class="list-group-item node-treeview10">

                <div id="forumTreeView_@item.Id">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="hdr_@item.Id">
                                <button class="forum-icon accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#branch_@item.Id" aria-expanded="true" aria-controls="branch_@item.Id">
                                    @Html.DisplayFor(modelItem => item.Title)
                                </button>
                            </h2>
                            <div id="branch_@item.Id" class="accordion-collapse collapse show" aria-labelledby="hdr_@item.Id" data-bs-parent="#forumTreeView_@item.Id">
                                <div class="accordion-body">
                                    <div class="d-flex flex-row justify-content-between">
                                        <div class="d-flex flex-column">
                                            <div class="d-flex">
                                                <span>@Html.DisplayFor(modelItem => item.Descriptions) <a href="/Forum/Details/@item.Id">...<img src="/src/arrow-right.svg" width="24" height="24" /></a></span>
                                            </div>
                                            <div class="d-flex flex-row">
                                                <a href="/Forum/Edit/@item.Id"><img src="/src/pencil-square.svg" width="24" height="24"/></a> 
                                                <a href="/Forum/Delete/@item.Id"><img src="/src/bucket.svg" width="24" height="24" /></a>
                                            </div>
                                            <div class="d-flex flex-row">
                                                <span><a href="/User/Details/@item.IdInitiator"> @Html.DisplayFor(modelItem => item.IdInitiatorNavigation.FullName)</a></span>
                                                <span> @Html.DisplayFor(modelItem => item.TimeCreate)</span>
                                            </div>
                                        </div>
                                        <div class="d-flex flex-row">
                                    <a title="Создать вложенный форум" class="btn rounded-circle lh-1" data-bs-toggle="offcanvas" data-bs-target="#offcanvasActionForum" aria-controls="offcanvasActionForum"
                                               onclick="GetCreateForumVC(1,@Model.Category.Id ,@item.Id );">
                                        <img src="/src/person-plus-fill.svg" width="24" height="24" />
                                    </a>
                                            <a title="Создать вопрос" class="btn rounded-circle lh-1" data-bs-toggle="offcanvas" data-bs-target="#offcanvasActionForum" aria-controls="offcanvasActionForum"
                                               onclick="GetCreateTopicVC(1,@item.Id ,@Model.Category.Id );">
                                                <img src="/src/question-circle.svg" width="24" height="24" />
                                            </a>
                                        </div>
                                    </div>
                                    <br />
                                    @if (item.TblTopics.Any())
                                    {
                                        <ul class="list-group">
                                            @foreach (var topic in item.TblTopics)
                                            {
                                                <li class="list-group-item node-treeview10">
                                                    <a href="#" class="topic-icon" style="color:inherit;">@Html.DisplayFor(topicItem => topic.Title)</a> | @Html.DisplayFor(topicItem => topic.Descriptions)
                                                    <br />
                                                    <a href="/Topic/Edit/@topic.Id">Edit</a> |
                                                    <a href="/Topic/Details/@topic.Id">Details</a> |
                                                    <a href="/Topic/Delete/@topic.Id">Delete</a>
                                                    <br />
                                                    @foreach (var tag in topic.IdTags)
                                                    {
                                                        @Html.DisplayFor(kw => tag.Tag)
                                                    }
                                                    <br />
                                                    @if (topic.IsAnonymous == true)
                                                    {
                                                        <label>Анонимный вопрос</label>
                                                    }
                                                    else
                                                    {
                                                        <a href="/User/Details/@topic.IdInitiator"> @Html.DisplayFor(modelItem => topic.IdInitiatorNavigation.FullName)</a>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if (item.InverseIdParentNavigation.Any())
                                    {
                                        ShowTreeData(item.InverseIdParentNavigation);
                                    }
                                </div>
                            </div>
                        </div>
                </div>
                </li>
            }
        </ul>
    }
}

